{
  "name": "vanilla-toast-js",
  "version": "1.0.3",
  "description": "A lightweight, framework-independent toast notification library for Vanilla JavaScript.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "vanilla-toast-js",
    "toast",
    "notification",
    "vanilla",
    "javascript",
    "typescript",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Github-Suriya/vanilla-toast-js.git"
  },
  "homepage": "https://github.com/Github-Suriya/vanilla-toast-js#readme",
  "bugs": {
    "url": "https://github.com/Github-Suriya/vanilla-toast-js/issues"
  },
  "main": "./dist/vanilla-toast.umd.js",
  "module": "./dist/vanilla-toast.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vanilla-toast.es.js",
      "require": "./dist/vanilla-toast.umd.js"
    },
    "./style.css": "./dist/vanilla-toast.css",
    "./vanilla-toast.css": "./dist/vanilla-toast.css",
    "./vanilla-toast.iife.js": "./dist/vanilla-toast.iife.js",
    "./vanilla-toast.umd.js": "./dist/vanilla-toast.umd.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --host=0.0.0.0 --port=3000",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run build:types && vite build",
    "preview": "vite preview --host=0.0.0.0",
    "lint": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
